<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>All Posts</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="container">
    <h1>Quora Posts</h1>

    <% for(let post of posts) { %>
        <div class="post">
            <h3 class="user">@<%= post.username %></h3>
            <p class="content"><%= post.content %></p>

            <div class="actions">
                <a class="view-btn" href="/posts/<%= post.id %>">View</a>
                <a class="edit-btn" href="/posts/<%= post.id %>/edit">Edit</a>

                <form method="POST" action="/posts/<%= post.id %>?_method=DELETE">
                    <button class="delete-btn">Delete</button>
                </form>
            </div>
        </div>
    <% } %>

    <a class="create-btn" href="/posts/new">Create New Post</a>
</div>

</body>
</html>
